{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/svelte-check.sh",
            "statusMessage": "Running svelte-check..."
          }
        ]
      }
    ]
  }
}
